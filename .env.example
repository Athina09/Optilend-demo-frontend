# Copy to .env.local and restart `npm run dev`.
# Optional: NEXT_TELEMETRY_DISABLED=1  (silences Next.js anonymous telemetry during build/dev)
# Scoring API (browser): optional direct URL; falls back to Next `/api/score` proxy.
NEXT_PUBLIC_SCORING_LAYER_URL=http://127.0.0.1:5055

# Next.js `/api/score` proxy target (server-side). Default is 127.0.0.1:5055 if unset.
# SCORING_API_URL=http://127.0.0.1:5055
