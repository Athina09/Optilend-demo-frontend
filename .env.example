# Copy to .env.local and restart `npm run dev`.

# Scoring API (browser): direct URL avoids Docker/server-only localhost issues.
NEXT_PUBLIC_SCORING_LAYER_URL=http://127.0.0.1:5055

# Next.js `/api/score` proxy target (server-side).
SCORING_API_URL=http://127.0.0.1:5055

# MSME chat widget → chatbot server (default port 5001).
NEXT_PUBLIC_CHAT_API_URL=http://127.0.0.1:5001
